{
  "name": "randomtripgenerator",
  "version": "1.0.1",
  "description": "Generate random trip destinations with geolocation and AI-powered suggestions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "build": "cd client && npm install && npm run build",
    "seo:generate": "node scripts/generateSeoPages.js",
    "seo:status": "node scripts/generateSeoPages.js --status"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "express-rate-limit": "^8.3.1",
    "pg": "^8.20.0"
  }
}
